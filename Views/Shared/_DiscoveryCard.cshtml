@model DiscoveryMovieViewModel

<article class="poster-card">
    <a class="poster-card__image" asp-controller="Home" asp-action="Movie" asp-route-id="@Model.Id" aria-label="View @Model.Title">
        @if (Model.PosterUrl is not null)
        {
            <img src="@Model.PosterUrl" alt="Poster for @Model.Title" loading="lazy" />
        }
        else
        {
            <span class="poster-card__placeholder" aria-hidden="true">@Model.Title.FirstOrDefault()</span>
        }
        <span class="poster-card__score"><span aria-hidden="true">★</span> @Model.Score</span>
        <span class="poster-card__view">View film <span aria-hidden="true">↗</span></span>
    </a>
    <div class="poster-card__copy">
        <h3><a asp-controller="Home" asp-action="Movie" asp-route-id="@Model.Id">@Model.Title</a></h3>
        <p>@Model.ReleaseYear</p>
    </div>
</article>
