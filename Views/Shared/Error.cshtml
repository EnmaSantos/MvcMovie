@model ErrorViewModel
@{
    ViewData["Title"] = "Something went wrong";
}

<section class="error-page page-width">
    <span class="error-page__number">500</span>
    <p class="eyebrow eyebrow--dark"><span></span> Unexpected plot twist</p>
    <h1>That scene didn’t go as planned.</h1>
    <p>Try returning to discovery. If the problem continues, the request ID below can help trace it.</p>
    @if (Model.ShowRequestId)
    {
        <code>@Model.RequestId</code>
    }
    <a class="button button--dark" asp-controller="Home" asp-action="Index">Back to discovery</a>
</section>
