@model Movie

@{
    ViewData["Title"] = $"Remove {Model.Title}";
}

<section class="confirm-page page-width">
    <div class="confirm-card">
        <div class="confirm-card__symbol" aria-hidden="true">×</div>
        <p class="eyebrow eyebrow--dark"><span></span> Remove from shelf</p>
        <h1>Let “@Model.Title” go?</h1>
        <p>This removes the entry from your personal catalog. The film will still be waiting for you in discovery.</p>

        <div class="confirm-card__movie">
            <div class="mini-cover cover-@(Model.Id % 6)">@Model.Title?.FirstOrDefault()</div>
            <div><strong>@Model.Title</strong><span>@Model.ReleaseDate.Year · @Model.Genre · @Model.Rating</span></div>
        </div>

        <form asp-action="Delete" data-confirm="Remove '@Model.Title' from your shelf?">
            <input type="hidden" asp-for="Id" />
            <a asp-action="Details" asp-route-id="@Model.Id" class="button button--quiet">Keep it</a>
            <button type="submit" class="button button--danger">Remove film</button>
        </form>
    </div>
</section>
