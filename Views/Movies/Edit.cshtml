@model Movie

@{
    ViewData["Title"] = $"Edit {Model.Title}";
}

<section class="form-page page-width">
    <a class="back-link back-link--dark" asp-action="Details" asp-route-id="@Model.Id"><span aria-hidden="true">←</span> Back to film</a>

    <div class="form-page__grid">
        <div class="form-page__intro">
            <p class="eyebrow eyebrow--dark"><span></span> Edit shelf entry</p>
            <h1>Fine-tune the details.</h1>
            <p>Keep your personal catalog accurate and useful.</p>
            <div class="form-page__art form-page__art--edit" aria-hidden="true">
                <span>EDIT</span>
                <div></div>
            </div>
        </div>

        <form asp-action="Edit" class="editor-card">
            <input type="hidden" asp-for="Id" />
            <div class="editor-card__heading">
                <span>@Model.Id.ToString("00")</span>
                <div><h2>@Model.Title</h2><p>Update the fields that have changed.</p></div>
            </div>
            <partial name="_MovieForm" model="Model" />
            <div class="editor-card__actions">
                <a asp-action="Details" asp-route-id="@Model.Id" class="button button--quiet">Cancel</a>
                <button type="submit" class="button button--accent">Save changes</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
