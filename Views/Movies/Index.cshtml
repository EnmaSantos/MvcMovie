@model MvcMovie.Models.MovieGenreViewModel

@{
    ViewData["Title"] = "Movie Library";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Movie Library</h1>
        <p class="text-muted mb-0">Search, filter, and maintain the catalog.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add Movie</a>
</div>

<form id="movie-filter-form" asp-controller="Movies" asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-3">
        <label asp-for="MovieGenre" class="form-label">Genre</label>
        <select asp-for="MovieGenre" asp-items="Model.Genres" class="form-select">
            <option value="">All genres</option>
        </select>
    </div>

    <div class="col-md-3">
        <label asp-for="MovieYear" class="form-label">Released since</label>
        <select asp-for="MovieYear" asp-items="Model.Years" class="form-select">
            <option value="">All years</option>
        </select>
    </div>

    <div class="col-md-4">
        <label asp-for="SearchString" class="form-label">Title</label>
        <input id="movie-search" type="search" asp-for="SearchString" class="form-control" placeholder="Press / to search" />
    </div>

    <div class="col-md-2 d-flex gap-2">
        <button type="submit" class="btn btn-dark">Filter</button>
        <button id="clear-filters" type="button" class="btn btn-outline-secondary">Clear</button>
    </div>
</form>

<p id="movie-result-count" class="small text-muted" aria-live="polite"></p>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Movies![0].Title)</th>
                <th>@Html.DisplayNameFor(model => model.Movies![0].ReleaseDate)</th>
                <th>@Html.DisplayNameFor(model => model.Movies![0].Genre)</th>
                <th>@Html.DisplayNameFor(model => model.Movies![0].Price)</th>
                <th>@Html.DisplayNameFor(model => model.Movies![0].Rating)</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Movies!)
            {
                <tr data-movie-row>
                    <td>@Html.DisplayFor(modelItem => item.Title)</td>
                    <td>@Html.DisplayFor(modelItem => item.ReleaseDate)</td>
                    <td>@Html.DisplayFor(modelItem => item.Genre)</td>
                    <td>@Html.DisplayFor(modelItem => item.Price)</td>
                    <td>@Html.DisplayFor(modelItem => item.Rating)</td>
                    <td class="text-end text-nowrap">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">View</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
