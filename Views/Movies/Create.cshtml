@model Movie

@{
    ViewData["Title"] = "Add a film";
}

<section class="form-page page-width">
    <a class="back-link back-link--dark" asp-action="Index"><span aria-hidden="true">←</span> Back to my shelf</a>

    <div class="form-page__grid">
        <div class="form-page__intro">
            <p class="eyebrow eyebrow--dark"><span></span> New shelf entry</p>
            <h1>Add a film worth keeping.</h1>
            <p>Capture the essentials now. You can always return and refine the details later.</p>
            <div class="form-page__art" aria-hidden="true">
                <span>PLAY</span>
                <div></div>
            </div>
        </div>

        <form asp-action="Create" class="editor-card">
            <div class="editor-card__heading">
                <span>01</span>
                <div><h2>Film details</h2><p>All fields are required.</p></div>
            </div>
            <partial name="_MovieForm" model="Model" />
            <div class="editor-card__actions">
                <a asp-action="Index" class="button button--quiet">Cancel</a>
                <button type="submit" class="button button--accent">Add to my shelf</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
